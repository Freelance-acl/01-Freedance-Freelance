# Database Configuration (placeholders - DO NOT commit real secrets)
# Copy this file to `.env` and fill in real values locally.
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Service Ports (external mappings)
USER_SERVICE_PORT=8081
JOB_SERVICE_PORT=8082
PROPOSAL_SERVICE_PORT=8083
CONTRACT_SERVICE_PORT=8084
WALLET_SERVICE_PORT=8085

# Docker Internal Service Port (container port for all services)
INTERNAL_SERVICE_PORT=8080
